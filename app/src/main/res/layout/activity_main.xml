<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="16dp">

    <!-- App Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status No Blur"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Post crispy statuses to WhatsApp"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Preview Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPreview"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        app:cardBackgroundColor="@color/card_bg"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintBottom_toTopOf="@id/btnPickImage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Placeholder text -->
            <LinearLayout
                android:id="@+id/placeholderLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="vertical"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📷"
                    android:textSize="48sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/select_media"
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <!-- Image preview -->
            <ImageView
                android:id="@+id/ivPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="Preview" />

            <!-- Video play icon overlay -->
            <ImageView
                android:id="@+id/ivPlayIcon"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play_circle"
                android:visibility="gone"
                android:contentDescription="Video" />

            <!-- Processing overlay -->
            <FrameLayout
                android:id="@+id/processingOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#AA000000"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ProgressBar
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:indeterminateTint="@color/accent" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/optimizing"
                        android:textColor="@color/white"
                        android:textSize="14sp"
                        android:layout_marginTop="12dp" />
                </LinearLayout>
            </FrameLayout>

            <!-- Status badge -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:background="@drawable/bg_status_badge"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- Pick Image Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPickImage"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/pick_image"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:backgroundTint="@color/card_bg"
        app:cornerRadius="14dp"
        app:icon="@drawable/ic_image"
        app:iconTint="@color/accent"
        app:layout_constraintBottom_toTopOf="@id/btnPickVideo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp" />

    <!-- Pick Video Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnPickVideo"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="@string/pick_video"
        android:textColor="@color/white"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:backgroundTint="@color/card_bg"
        app:cornerRadius="14dp"
        app:icon="@drawable/ic_video"
        app:iconTint="@color/accent"
        app:layout_constraintBottom_toTopOf="@id/btnShare"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp" />

    <!-- Share Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnShare"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="@string/optimize_and_share"
        android:textColor="@color/black"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        android:enabled="false"
        app:backgroundTint="@color/accent"
        app:cornerRadius="14dp"
        app:icon="@drawable/ic_share"
        app:iconTint="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
